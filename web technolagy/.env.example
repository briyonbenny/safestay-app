MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/safestay
SESSION_SECRET=change-this-to-a-strong-secret
PORT=3000

# Optional: if NODE_ENV=production but the API is reached over http:// (rare local test), set to allow session cookies:
# SESSION_INSECURE_COOKIES=true

# When the React app is on another origin (e.g. Render static site). Use exact origins, no trailing slash.
# Multiple: comma-separated — e.g. Render + local Vite against the same API:
# CLIENT_ORIGIN=https://your-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173
# Or keep only the Render URL and set CORS_ALLOW_LOCALHOST=true so local dev can call the deployed API.
# CLIENT_ORIGIN=https://your-frontend.onrender.com
# CORS_ALLOW_LOCALHOST=true
