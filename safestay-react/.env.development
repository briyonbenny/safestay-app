# Loaded when you run `npm run dev` from safestay-react.
VITE_USE_API=true

# Must match the API listen port (see terminal: "SafeStay server listening on port …").
# Default in web technolagy/app.js is 3000 unless PORT is set in web technolagy/.env (e.g. 5000).
# (Direct URL helps session cookies; Vite proxy target follows this value in vite.config.js.)
# Use the SAME host you use in the browser: localhost vs 127.0.0.1 must match here.
VITE_API_BASE_URL=http://localhost:5000

# If the API runs on 3000 instead, use: http://localhost:3000
# If you open the app at http://127.0.0.1:5173, use e.g. http://127.0.0.1:5000
