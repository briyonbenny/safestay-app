# Connect the React app to the Node + MongoDB backend (see web technolagy/):
# 1) Local: run the API (e.g. npm start in web technolagy) on port 3000, run Vite (npm run dev) — Vite proxies /api to 3000.
# 2) Set the next line to "true" (or set VITE_API_BASE_URL to your deployed API origin).
# VITE_USE_API=true
#
# Production: your Render (or other) API URL, no trailing slash. Also set the same value as CLIENT_ORIGIN on the API (Render) for CORS.
# VITE_API_BASE_URL=https://your-api.onrender.com
